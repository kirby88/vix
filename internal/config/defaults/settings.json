{
  "version": 1,
  "agent": "general",
  "theme": {
    "primary": "#BC63FC",
    "secondary": "#A3FC63"
  },
  "features": {
    "tool_orchestrator": false,
    "read_claude_md": true,
    "read_agents_md": true
  },
  "lsp": {
  },
  "workflows": [
    {
      "name": "Plan",
      "entry_point": {
        "id": "explore",
        "params": {
          "prompt": "$(workflow.prompt)"
        }
      },
      "steps": {
        "explore": {
          "type": "agent",
          "agent": "general",
          "input_params": {
            "prompt": {
              "description": "The user's plan description"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/explore.md)",
          "next_steps": [
            {
              "id": "plan",
              "params": {
                "prompt": "$(step.explore.prompt)"
              }
            }
          ],
          "stream": true,
          "explanation": "Exploring the codebase to understand relevant files and patterns"
        },
        "plan": {
          "type": "agent",
          "fork_from": "explore",
          "input_params": {
            "prompt": {
              "description": "The user's plan description"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/plan.md)",
          "next_steps": [
            {
              "id": "review",
              "params": {
                "plan": "$(step.plan)"
              }
            }
          ],
          "stream": true,
          "json_output": false,
          "explanation": "Generating a draft implementation plan"
        },
        "review": {
          "type": "tool",
          "tool": "ask_question_to_user",
          "question": "Review the plan above. What would you like to do?",
          "input_params": {
            "plan": {
              "description": "The LLM's plan to address the user ask"
            }
          },
          "options": [
            {
              "title": "Accept",
              "description": "Approve the plan and proceed to execution",
              "steps": [
                {
                  "id": "execute",
                  "params": {
                    "plan": "$(plan)"
                  }
                }
              ]
            },
            {
              "title": "Modify",
              "description": "Provide feedback to refine the plan",
              "steps": [
                {
                  "id": "refine",
                  "params": {
                    "feedback": "The user reviewed the plan and gave you the following feedback you need to address: $(user_text)"
                  }
                }
              ],
              "has_user_input": true
            },
            {
              "title": "Reject",
              "description": "Reject the plan and stop the workflow",
              "steps": [
                {
                  "id": "stop"
                }
              ]
            }
          ],
          "category": "Plan Review",
          "explanation": "Reviewing the plan"
        },
        "refine": {
          "type": "agent",
          "fork_from": "plan",
          "input_params": {
            "feedback": {
              "description": "User feedback to refine the plan"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/refine.md)",
          "next_steps": [
            {
              "params": {
                "plan": "$(step.refine)"
              },
              "id": "review"
            }
          ],
          "stream": true,
          "json_output": false,
          "explanation": "Refining the plan based on critique feedback"
        },
        "execute": {
          "input_params": {
            "plan": {
              "description": "The LLM's plan for updating the code"
            }
          },
          "type": "agent",
          "agent": "general",
          "prompt": "$(file:prompts/plan_workflow/execute.md)",
          "explanation": "Executing the approved plan",
          "stream": true
        }
      }
    },
    {
      "name": "Plan & Critic (more resources intensive)",
      "entry_point": {
        "id": "explore",
        "params": {
          "prompt": "$(workflow.prompt)"
        }
      },
      "steps": {
        "explore": {
          "type": "agent",
          "agent": "general",
          "input_params": {
            "prompt": {
              "description": "The user's plan description"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/explore.md)",
          "next_steps": [
            {
              "id": "plan",
              "params": {
                "prompt": "$(step.explore.prompt)"
              }
            }
          ],
          "stream": true,
          "explanation": "Exploring the codebase to understand relevant files and patterns"
        },
        "plan": {
          "type": "agent",
          "fork_from": "explore",
          "input_params": {
            "prompt": {
              "description": "The user's plan description"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/plan.md)",
          "next_steps": [
            {
              "id": "critique",
              "params": {
                "plan": "$(step.plan)",
                "prompt": "$(step.plan.prompt)"
              }
            }
          ],
          "stream": true,
          "json_output": false,
          "explanation": "Generating a draft implementation plan"
        },
        "critique": {
          "type": "agent",
          "fork_from": "explore",
          "input_params": {
            "prompt": {
              "description": "The user's plan description"
            },
            "plan": {
              "description": "The user's plan description"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/critique.md)",
          "next_steps": [
            {
              "id": "refine",
              "params": {
                "feedback": "$(step.critique)"
              }
            }
          ],
          "stream": true,
          "explanation": "Reviewing the plan for flaws, gaps, and risks"
        },
        "refine": {
          "type": "agent",
          "fork_from": "plan",
          "input_params": {
            "feedback": {
              "description": "User feedback to refine the plan"
            }
          },
          "prompt": "$(file:prompts/plan_workflow/refine.md)",
          "next_steps": [
            {
              "params": {
                "plan": "$(step.refine)"
              },
              "id": "review"
            }
          ],
          "stream": true,
          "json_output": false,
          "explanation": "Refining the plan based on critique feedback"
        },
        "review": {
          "type": "tool",
          "tool": "ask_question_to_user",
          "question": "Review the plan above. What would you like to do?",
          "input_params": {
            "plan": {
              "description": "The LLM's plan to address the user ask"
            }
          },
          "options": [
            {
              "title": "Accept",
              "description": "Approve the plan and proceed to execution",
              "steps": [
                {
                  "id": "execute",
                  "params": {
                    "plan": "$(plan)"
                  }
                }
              ]
            },
            {
              "title": "Modify",
              "description": "Provide feedback to refine the plan",
              "steps": [
                {
                  "id": "refine",
                  "params": {
                    "feedback": "The user reviewed the plan and gave you the following feedback you need to address: $(user_text)"
                  }
                }
              ],
              "has_user_input": true
            },
            {
              "title": "Reject",
              "description": "Reject the plan and stop the workflow",
              "steps": [
                {
                  "id": "stop"
                }
              ]
            }
          ],
          "category": "Plan Review",
          "explanation": "Reviewing the plan"
        },
        "execute": {
          "input_params": {
            "plan": {
              "description": "The LLM's plan for updating the code"
            }
          },
          "type": "agent",
          "agent": "general",
          "prompt": "$(file:prompts/plan_workflow/execute.md)",
          "explanation": "Executing the approved plan",
          "stream": true
        }
      }
    }
  ]
}